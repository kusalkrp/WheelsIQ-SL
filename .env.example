# ============================================================
# Prime Wheels SL — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# PostgreSQL
PG_PASSWORD=changeme_in_production

# Google Gemini API (only paid component)
GEMINI_API_KEY=your_gemini_api_key_here

# LangFuse (self-hosted observability)
LANGFUSE_SECRET=changeme_langfuse_secret
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Traefik ACME (SSL certificate)
ACME_EMAIL=your_email@example.com

# App
APP_ENV=development
LOG_LEVEL=INFO
